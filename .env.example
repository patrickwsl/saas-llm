ENV=local

# Logging (json = uma linha JSON por evento, ideal para agregadores)
SERVICE_NAME=saas-llm
LOG_LEVEL=INFO
LOG_FORMAT=console

# PostgreSQL (exemplo):
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/saas_llm
DATABASE_URL=

# Segurança / chaves
APP_SECRET_KEY=change-me

# OpenAI (para etapa RAG)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Uploads
UPLOAD_DIR=app/uploads
CHROMA_DIR=app/chroma

